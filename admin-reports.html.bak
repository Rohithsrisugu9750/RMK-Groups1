<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Reports | RMK Groups</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="admin.css">
</head>

<body>
    <div class="preloader">
        <div class="loader-content">
            <img src="logo.png" alt="RMK Groups" class="loader-logo">
            <div class="loader-spinner"></div>
        </div>
    </div>

    <header class="admin-header">
        <div class="admin-header-content">
            <button class="mobile-sidebar-toggle" id="sidebarToggle">
                <i class="fas fa-bars"></i>
            </button>
            <div class="admin-logo">
                <img src="logo.png" alt="RMK Groups" style="height: 50px; width: auto;">
                <span class="admin-badge">Admin</span>
            </div>
            <div class="admin-user">
                <div class="notification-icon">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </div>
                <div class="user-profile">
                    <img src="https://ui-avatars.com/api/?name=Admin+User&background=064E3B&color=fff" alt="Admin">
                    <div class="user-info">
                        <span class="user-name">Admin User</span>
                        <span class="user-role">Administrator</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <aside class="admin-sidebar">
        <nav class="sidebar-nav">
            <a href="admin-billing.html" class="nav-item">
                <i class="fas fa-file-invoice-dollar"></i>
                <span>Billing</span>
            </a>
            <a href="admin-customers.html" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Customers</span>
            </a>
            <a href="admin-products.html" class="nav-item">
                <i class="fas fa-box"></i>
                <span>Products</span>
            </a>
            <a href="admin-inventory.html" class="nav-item">
                <i class="fas fa-warehouse"></i>
                <span>Inventory</span>
            </a>

            <a href="admin-reports.html" class="nav-item active">
                <i class="fas fa-chart-bar"></i>
                <span>Reports</span>
            </a>
            <a href="admin-settings.html" class="nav-item">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="index.html" class="nav-item">
                <i class="fas fa-globe"></i>
                <span>View Website</span>
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="page-header">
            <div>
                <h1 class="page-title">Reports & Analytics</h1>
                <p class="page-subtitle">Business performance and insights</p>
            </div>
            <div class="page-actions">
                <button class="btn btn-secondary" id="exportAttendanceBtn">
                    <i class="fas fa-file-excel"></i> Export Attendance
                </button>
                <button class="btn btn-secondary" id="exportGstBtn">
                    <i class="fas fa-file-excel"></i> Export GST (Excel)
                </button>
                <button class="btn btn-primary" id="downloadReportBtn">
                    <i class="fas fa-download"></i> Download PDF
                </button>
            </div>
        </div>

        <div class="stats-grid">
            <div class="stat-card">
                <div class="stat-icon blue">
                    <i class="fas fa-rupee-sign"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-value">0</h3>
                    <p class="stat-label">Total Revenue</p>
                    <span class="stat-change neutral"><i class="fas fa-minus"></i> 0%</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon purple">
                    <i class="fas fa-shopping-cart"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-value">0</h3>
                    <p class="stat-label">Total Orders</p>
                    <span class="stat-change neutral"><i class="fas fa-minus"></i> 0%</span>
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-icon orange">
                    <i class="fas fa-chart-line"></i>
                </div>
                <div class="stat-content">
                    <h3 class="stat-value">0</h3>
                    <p class="stat-label">Avg. Order Value</p>
                    <span class="stat-change neutral"><i class="fas fa-minus"></i> 0%</span>
                </div>
            </div>
        </div>

        <div class="form-row">
            <div class="form-group flex-2">
                <h3 class="settings-title">Revenue Overview</h3>
                <div class="report-chart">
                    <!-- Placeholder for chart -->
                    <div style="text-align:center">
                        <i class="fas fa-chart-area" style="font-size:3rem; margin-bottom:1rem; opacity:0.5"></i>
                        <p>No data available</p>
                    </div>
                </div>
            </div>
            <div class="form-group">
                <h3 class="settings-title">Top Selling Products</h3>
                <div class="data-table-container">
                    <table class="data-table">
                        <tbody>
                            <!-- Data cleared -->
                            <tr>
                                <td colspan="2" style="text-align:center; padding: 1rem;">No data</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="form-row" style="margin-top: 2rem;">
            <div class="form-group flex-2">
                <h3 class="settings-title">Monthly GST Summary (GSTR-1 Ready)</h3>
                <div class="data-table-container">
                    <table class="data-table" id="gstSummaryTable">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th>Taxable Value</th>
                                <th>CGST</th>
                                <th>SGST</th>
                                <th>IGST</th>
                                <th>Total Tax</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Aggregated via JS -->
                            <tr>
                                <td colspan="6" style="text-align:center; padding: 1rem;">No tax data available</td>
                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </main>

    <div class="print-only">
        <div class="report-print-container">
            <div class="report-header">
                <div class="header-left">
                    <img src="logo.png" alt="Logo" class="print-logo">
                    <div class="brand-info">
                        <h2>RMK Groups</h2>
                        <p>Most Trusted Brand Since 1987</p>
                    </div>
                </div>
                <div class="header-right">
                    <h1 class="report-title">BUSINESS PERFORMANCE REPORT</h1>
                    <div class="report-meta">
                        <span><i class="fas fa-calendar-alt"></i> Date: <strong id="printDate"></strong></span>
                    </div>
                </div>
            </div>

            <div class="report-section summary-grid">
                <div class="summary-card revenue">
                    <div class="card-icon"><i class="fas fa-rupee-sign"></i></div>
                    <div class="card-data">
                        <span class="label">Total Revenue</span>
                        <h3 class="value" id="printRevenue">₹0</h3>
                    </div>
                </div>
                <div class="summary-card orders">
                    <div class="card-icon"><i class="fas fa-shopping-cart"></i></div>
                    <div class="card-data">
                        <span class="label">Total Orders</span>
                        <h3 class="value" id="printOrders">0</h3>
                    </div>
                </div>
                <div class="summary-card avg-order">
                    <div class="card-icon"><i class="fas fa-chart-line"></i></div>
                    <div class="card-data">
                        <span class="label">Avg. Order Value</span>
                        <h3 class="value" id="printAvgOrder">₹0</h3>
                    </div>
                </div>
            </div>

            <div class="report-section">
                <h3 class="section-title">GST Summary (GSTR-1)</h3>
                <div class="print-table-wrapper">
                    <table class="report-table" id="printGstSummary">
                        <thead>
                            <tr>
                                <th>Month</th>
                                <th style="text-align:right">Taxable Value</th>
                                <th style="text-align:right">CGST</th>
                                <th style="text-align:right">SGST</th>
                                <th style="text-align:right">IGST</th>
                                <th style="text-align:right">Total Tax</th>
                            </tr>
                        </thead>
                        <tbody>
                            <!-- Populated via script -->
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="report-footer">
                <div class="footer-info">
                    <p>Generated by RMK Groups Admin System</p>
                    <p>Ariyalur Main Road, Perambalur • Customer Care: 8248838593</p>
                </div>
                <div class="signature-section">
                    <div class="sig-line"></div>
                    <p>Authorized Signature</p>
                </div>
            </div>
        </div>
    </div>

    <script src="admin.js"></script>
</body>

</html>