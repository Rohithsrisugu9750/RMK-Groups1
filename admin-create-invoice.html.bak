<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Invoice | RMK Fly Ash Bricks</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@700;800;900&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="admin.css">
    <style>
        .page-form-wrap {
            max-width: 900px;
            margin: 0 auto;
        }
        .form-card {
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
            border: 1px solid #F3F4F6;
            margin-bottom: 1.5rem;
            overflow: hidden;
        }
        .form-card-header {
            background: linear-gradient(135deg, #064E3B, #065F46);
            padding: 1.1rem 1.75rem;
            display: flex;
            align-items: center;
            gap: 0.75rem;
        }
        .form-card-header h3 {
            color: #fff;
            font-size: 1rem;
            font-weight: 700;
            margin: 0;
        }
        .form-card-header i {
            color: rgba(255,255,255,0.75);
            font-size: 1rem;
        }
        .form-card-body {
            padding: 1.75rem;
        }
        .calc-summary {
            background: #F9FAFB;
            border-radius: 12px;
            padding: 1.25rem 1.5rem;
            margin-top: 1rem;
            border: 1px solid #E5E7EB;
        }
        .calc-row {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.45rem 0;
            font-size: 0.92rem;
            color: #374151;
            border-bottom: 1px solid #F3F4F6;
        }
        .calc-row:last-child { border-bottom: none; }
        .calc-row.total {
            font-size: 1.1rem;
            font-weight: 800;
            color: #064E3B;
            padding-top: 0.75rem;
            margin-top: 0.25rem;
            border-top: 2px solid #E5E7EB;
            border-bottom: none;
        }
        .calc-row strong { font-weight: 700; color: #111827; }
        .product-item {
            background: #F9FAFB;
            border-radius: 10px;
            padding: 1rem;
            margin-bottom: 0.75rem;
            border: 1px solid #E5E7EB;
            position: relative;
        }
        .btn-icon-danger {
            background: #FEF2F2;
            color: #DC2626;
            border: 1px solid #FECACA;
            border-radius: 8px;
            padding: 0.6rem 0.75rem;
            cursor: pointer;
            font-size: 0.85rem;
            transition: all 0.2s;
            margin-top: auto;
        }
        .btn-icon-danger:hover { background: #DC2626; color: #fff; }
        .form-group-action { display: flex; align-items: flex-end; }
        .page-action-bar {
            display: flex;
            gap: 1rem;
            justify-content: flex-end;
            padding: 1.5rem;
            background: #fff;
            border-radius: 16px;
            box-shadow: 0 4px 24px rgba(0,0,0,0.07);
            border: 1px solid #F3F4F6;
            flex-wrap: wrap;
        }
        .toggle-switch { display: flex; align-items: center; gap: 0.5rem; }
        .toggle-input { display: none; }
        .toggle-label {
            width: 48px; height: 26px;
            background: #D1D5DB;
            border-radius: 13px;
            cursor: pointer;
            position: relative;
            transition: background 0.2s;
        }
        .toggle-label::after {
            content: '';
            position: absolute;
            width: 20px; height: 20px;
            background: #fff;
            border-radius: 50%;
            top: 3px; left: 3px;
            transition: left 0.2s;
            box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        }
        .toggle-input:checked + .toggle-label { background: #064E3B; }
        .toggle-input:checked + .toggle-label::after { left: 25px; }
        .btn-save-only {
            background: #E2E8F0; color: #475569;
            border: 1px solid #CBD5E1;
            padding: 0.75rem 1.5rem;
            border-radius: 8px; font-weight: 600;
            cursor: pointer; display: inline-flex;
            align-items: center; gap: 0.5rem;
            font-size: 0.95rem; transition: all 0.2s;
        }
        .btn-save-only:hover { background: #CBD5E1; }
        .btn-print {
            background: #064E3B; color: #fff;
            border: none;
            padding: 0.75rem 1.75rem;
            border-radius: 8px; font-weight: 700;
            cursor: pointer; display: inline-flex;
            align-items: center; gap: 0.5rem;
            font-size: 0.95rem; transition: all 0.2s;
            box-shadow: 0 4px 12px rgba(6,78,59,0.3);
        }
        .btn-print:hover { background: #065F46; box-shadow: 0 6px 16px rgba(6,78,59,0.4); transform: translateY(-1px); }
    </style>
</head>
<body>
    <!-- Header -->
    <header class="admin-header">
        <div class="admin-header-content">
            <button class="mobile-sidebar-toggle" id="sidebarToggle"><i class="fas fa-bars"></i></button>
            <div class="admin-logo">
                <img src="logo.png" alt="RMK Fly Ash Bricks" style="height:50px;width:auto;">
                <span class="admin-badge">Admin</span>
                <span id="connectionStatus" class="connection-status offline">Connecting...</span>
                <span id="dbStatus" class="connection-status offline" style="margin-left:10px;background:#95a5a6;padding:4px 10px;border-radius:20px;font-size:11px;">DB: Offline</span>
            </div>
            <div class="admin-user">
                <div class="user-profile">
                    <img src="https://ui-avatars.com/api/?name=Admin+User&background=064E3B&color=fff" alt="Admin">
                    <div class="user-info">
                        <span class="user-name">Admin User</span>
                        <span class="user-role">Administrator</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <!-- Sidebar -->
    <aside class="admin-sidebar">
        <nav class="sidebar-nav">
            <a href="admin-billing.html" class="nav-item active"><i class="fas fa-file-invoice-dollar"></i><span>Billing</span></a>
            <a href="admin-customers.html" class="nav-item"><i class="fas fa-users"></i><span>Customers</span></a>
            <a href="admin-products.html" class="nav-item"><i class="fas fa-box"></i><span>Products</span></a>
            <a href="admin-inventory.html" class="nav-item"><i class="fas fa-warehouse"></i><span>Inventory</span></a>
            
            
            <a href="admin-reports.html" class="nav-item"><i class="fas fa-chart-bar"></i><span>Reports</span></a>
            <a href="admin-settings.html" class="nav-item"><i class="fas fa-cog"></i><span>Settings</span></a>
        </nav>
        <div class="sidebar-footer">
            <a href="index.html" class="nav-item"><i class="fas fa-globe"></i><span>View Website</span></a>
            <a href="#" class="nav-item logout"><i class="fas fa-sign-out-alt"></i><span>Logout</span></a>
        </div>
    </aside>

    <!-- Main Content -->
    <main class="admin-main">
        <div class="page-header">
            <div class="page-title-section">
                <h1 class="page-title"><i class="fas fa-file-invoice-dollar" style="color:#064E3B;margin-right:0.5rem;font-size:1.6rem;"></i>Create Invoice</h1>
                <p class="page-subtitle">Fill in the details below to generate a new invoice</p>
            </div>
            <a href="admin-billing.html" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Back to Billing</a>
        </div>

        <form id="invoiceForm" class="page-form-wrap">
            <!-- Customer Info -->
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-user"></i>
                    <h3>Customer Information</h3>
                </div>
                <div class="form-card-body">
                    <div class="form-row form-row-small">
                        <div class="form-group">
                            <label>Invoice Date *</label>
                            <input type="date" id="invDate" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label>Invoice Number *</label>
                            <input type="text" id="invNumber" class="form-control" placeholder="Auto-generated" required autocomplete="off">
                        </div>
                    </div>
                    <div class="form-row">
                        <div class="form-group">
                            <label>Customer Name</label>
                            <select id="invCustomerName" class="form-control">
                                <option value="">-- Select saved customer --</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Or Custom Client Name</label>
                            <input type="text" id="invCustomClientName" class="form-control" placeholder="Type client name directly..." autocomplete="off">
                            <small style="color:#6B7280;font-size:0.78rem;margin-top:3px;display:block;">Leave blank to use selected customer above.</small>
                        </div>
                    </div>
                    <div class="form-row" id="customClientDetails">
                        <div class="form-group">
                            <label>Mobile Number</label>
                            <input type="tel" id="invCustomClientMobile" class="form-control" placeholder="10-digit Mobile Number">
                        </div>
                        <div class="form-group">
                            <label>GST Number</label>
                            <input type="text" id="invCustomClientGst" class="form-control" placeholder="GST Number (optional)">
                        </div>
                    </div>
                    <div class="form-row" id="customClientAddressDetails">
                        <div class="form-group" style="width:100%;">
                            <label>Address</label>
                            <input type="text" id="invCustomClientAddress" class="form-control" placeholder="Full Client Address">
                        </div>
                    </div>
                </div>
            </div>

            <!-- Product Details -->
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-box"></i>
                    <h3>Product Details</h3>
                </div>
                <div class="form-card-body">
                    <div id="invProductItems"></div>
                    <button type="button" class="btn btn-outline" id="invAddProductBtn" style="margin-top:0.5rem;">
                        <i class="fas fa-plus"></i> Add Product
                    </button>
                </div>
            </div>

            <!-- Tax & Total -->
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-calculator"></i>
                    <h3>Tax &amp; Total</h3>
                </div>
                <div class="form-card-body">
                    <div class="form-row">
                        <div class="form-group">
                            <label>Apply GST</label>
                            <div class="toggle-switch">
                                <input type="checkbox" id="invGstToggle" class="toggle-input">
                                <label for="invGstToggle" class="toggle-label"></label>
                            </div>
                        </div>
                        <div class="form-group">
                            <label>GST Rate (%)</label>
                            <select id="invGstRate" class="form-control" disabled>
                                <option value="0">0%</option>
                                <option value="5">5%</option>
                                <option value="12">12%</option>
                                <option value="18" selected>18%</option>
                                <option value="28">28%</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label>Tax Type</label>
                            <select id="invTaxType" class="form-control">
                                <option value="intra">Intrastate (CGST + SGST)</option>
                                <option value="inter">Interstate (IGST)</option>
                            </select>
                        </div>
                    </div>
                    <div class="calc-summary">
                        <div class="calc-row"><span>Subtotal (Taxable Value):</span><strong id="invSubtotalAmount">₹0.00</strong></div>
                        <div id="invTaxSplitRows">
                            <div class="calc-row inv-intra-only"><span>CGST (<span class="inv-half-gst">0</span>%):</span><strong class="inv-cgst-amount">₹0.00</strong></div>
                            <div class="calc-row inv-intra-only"><span>SGST (<span class="inv-half-gst">0</span>%):</span><strong class="inv-sgst-amount">₹0.00</strong></div>
                            <div class="calc-row inv-inter-only" style="display:none"><span>IGST (<span id="invGstPercentage">0</span>%):</span><strong id="invGstAmount">₹0.00</strong></div>
                        </div>
                        <div class="calc-row" style="margin-top:10px;align-items:center;">
                            <span>Amount Received (₹):</span>
                            <input type="number" id="invReceivedAmount" class="form-control" style="width:140px;text-align:right;margin:0;" placeholder="0.00" value="0">
                        </div>
                        <div class="calc-row" style="color:#e74c3c;"><span>Balance Due:</span><strong id="invBalanceAmount">₹0.00</strong></div>
                        <div class="calc-row total"><span>Grand Total:</span><strong id="invTotalAmount">₹0.00</strong></div>
                    </div>
                </div>
            </div>

            <!-- Payment Terms -->
            <div class="form-card">
                <div class="form-card-header">
                    <i class="fas fa-file-alt"></i>
                    <h3>Payment Terms &amp; Notes</h3>
                </div>
                <div class="form-card-body">
                    <div class="form-group">
                        <textarea id="invNotes" class="form-control" rows="3">Payment due within 15 days. Interest @18% pa will be charged on delayed payments.</textarea>
                    </div>
                </div>
            </div>

            <!-- Actions -->
            <div class="page-action-bar">
                <a href="admin-billing.html" class="btn btn-secondary"><i class="fas fa-times"></i> Cancel</a>
                <button type="button" id="saveInvoiceOnlyBtn" class="btn-save-only">
                    <i class="fas fa-save"></i> Save ONLY
                </button>
                <button type="submit" id="createAndPrintBtn" class="btn-print">
                    <i class="fas fa-print"></i> Save &amp; Print Bill
                </button>
            </div>
        </form>
    </main>

    <!-- Printable Invoice Template -->
    <div id="printTemplate" class="print-only">
        <div class="new-print-layout">
            <div class="n-header-wrap">
                <div class="n-header-left">
                    <img src="logo.png" id="printLogo" class="n-logo" alt="Logo">
                    <div class="n-brand-text">Most Trusted Brand</div>
                </div>
                <div class="n-header-center">
                    <h2 class="n-company-name" style="display: inline-block; text-align: center; margin: 0;">R.M.K<br><span style="font-size: 0.85em;">FLYASH BRICKS & PAVER BLOCK</span></h2>
                    <p id="pCompanyAddress">SFNO:281/5A, ARIYALUR MAIN ROAD, KAULPALAYAM, THURAIMANGALAM - POST, PERAMBALUR - 621 220<br>+91 82488 38593, +91 99520 68848 | rmkgroups1987@gmail.com</p>
                    <p id="pCompanyGstContainer" style="margin-top:5px; font-size:24px; font-weight:900; color: #000;">GSTIN-33CFVPK8449D1ZO</p>
                </div>
            </div>
            <div class="n-divider-line"></div>
            <div class="n-meta-row">
                <div class="n-meta-box">
                    <div class="n-meta-item" style="white-space: nowrap;"><span>#:</span> <strong id="pInvNumber"></strong></div>
                    <div class="n-meta-item"><span>Date:</span> <strong id="pInvDate"></strong></div>
                </div>
                <div class="n-doc-subtitle"><h1 id="pDocTitle">INVOICE</h1></div>
            </div>
            <div class="n-bill-to-row">
                <div class="n-bill-to-title">Bill To</div>
                <div class="n-bill-to-name" id="pCustomerName" style="font-weight:800;font-size:11px;"></div>
                <div id="pCustomerAddress" style="font-size:9px;margin-top:2px;"></div>
                <div id="pCustomerGstContainer" style="display:none;font-size:8px;margin-top:2px;"><strong>GSTIN: </strong><span id="pCustomerGst"></span></div>
                <div id="pCustomerPhoneContainer" style="display:none;font-size:8px;margin-top:1px;"><strong>Phone: </strong><span id="pCustomerPhone"></span></div>
            </div>
            <table class="n-print-table">
                <thead>
                    <tr>
                        <th style="width:5%">#</th>
                        <th style="text-align:left;width:55%">Item &amp; Description</th>
                        <th style="text-align:right;width:10%">Qty</th>
                        <th style="text-align:right;width:10%">Rate</th>
                        <th style="text-align:right;width:20%">Amount</th>
                    </tr>
                </thead>
                <tbody id="pProductRows"></tbody>
            </table>
            <div class="n-bottom-split">
                <div class="n-bottom-left">
                    <div class="n-total-words"><div>Total In Words</div><strong id="pTotalWords"></strong></div>
                    <div class="n-notes-section">
                        <div class="n-notes-title">Notes</div>
                        <div class="n-notes-content">Thanking You,<br>RMK Fly Ash Bricks,<br>Karthick (MD) Phone no: 9942068848<br>Customer Care: 8248838593</div>
                    </div>
                    <div class="n-terms-section">
                        <div class="n-terms-title">Terms &amp; Conditions</div>
                        <div class="n-terms-content" id="pTerms"></div>
                    </div>
                </div>
                <div class="n-bottom-right">
                    <table class="n-totals-table">
                        <tr><td class="n-tot-label">Sub Total</td><td class="n-tot-val" id="pSubtotal"></td></tr>
                        <tr id="rowCgst" style="display:none;"><td class="n-tot-label">CGST <span id="pCgstLabel"></span></td><td class="n-tot-val" id="pCgst"></td></tr>
                        <tr id="rowSgst" style="display:none;"><td class="n-tot-label">SGST <span id="pSgstLabel"></span></td><td class="n-tot-val" id="pSgst"></td></tr>
                        <tr id="rowIgst" style="display:none;"><td class="n-tot-label">IGST <span id="pIgstLabel"></span></td><td class="n-tot-val" id="pIgst"></td></tr>
                        <tr id="pRowReceived" style="display:none;"><td class="n-tot-label">Received</td><td class="n-tot-val" id="pReceived"></td></tr>
                        <tr id="pRowBalance" style="display:none;"><td class="n-tot-label">Balance Due</td><td class="n-tot-val" id="pBalance" style="color:#c0392b;"></td></tr>
                        <tr class="n-grandtotal-row"><td class="n-tot-label">Total</td><td class="n-tot-val" id="pTotal"></td></tr>
                    </table>
                    <div class="n-signature-box">
                        <img id="printSignature" src="" alt="" style="max-height:40px;display:none;margin:0 auto;padding-bottom:5px;">
                        <div class="n-sig-line">Authorized Signature</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="toast" id="successToast"><i class="fas fa-check-circle"></i><span>Invoice saved!</span></div>

    <script src="/socket.io/socket.io.js"></script>
    <script src="realtime.js"></script>
    <script src="email_config.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="admin.js"></script>
    <script src="admin-pages.js"></script>
</body>
</html>
