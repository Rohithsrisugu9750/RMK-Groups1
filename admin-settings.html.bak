<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Settings | RMK Groups</title>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=Montserrat:wght@700;800;900&display=swap"
        rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="admin.css">
</head>

<body>
    <div class="preloader">
        <div class="loader-content">
            <img src="logo.png" alt="RMK Groups" class="loader-logo">
            <div class="loader-spinner"></div>
        </div>
    </div>

    <header class="admin-header">
        <div class="admin-header-content">
            <button class="mobile-sidebar-toggle" id="sidebarToggle">
                <i class="fas fa-bars"></i>
            </button>
            <div class="admin-logo">
                <img src="logo.png" alt="RMK Fly Ash Bricks" style="height: 50px; width: auto;">
                <span class="admin-badge">Admin</span>
            </div>
            <div class="admin-user">
                <div class="notification-icon">
                    <i class="fas fa-bell"></i>
                    <span class="notification-badge">3</span>
                </div>
                <div class="user-profile">
                    <img src="https://ui-avatars.com/api/?name=Admin+User&background=064E3B&color=fff" alt="Admin">
                    <div class="user-info">
                        <span class="user-name">Admin User</span>
                        <span class="user-role">Administrator</span>
                    </div>
                </div>
            </div>
        </div>
    </header>

    <aside class="admin-sidebar">
        <nav class="sidebar-nav">
            <a href="admin-billing.html" class="nav-item">
                <i class="fas fa-file-invoice-dollar"></i>
                <span>Billing</span>
            </a>
            <a href="admin-customers.html" class="nav-item">
                <i class="fas fa-users"></i>
                <span>Customers</span>
            </a>
            <a href="admin-products.html" class="nav-item">
                <i class="fas fa-box"></i>
                <span>Products</span>
            </a>
            <a href="admin-inventory.html" class="nav-item">
                <i class="fas fa-warehouse"></i>
                <span>Inventory</span>
            </a>

            <a href="admin-reports.html" class="nav-item">
                <i class="fas fa-chart-bar"></i>
                <span>Reports</span>
            </a>
            <a href="admin-settings.html" class="nav-item active">
                <i class="fas fa-cog"></i>
                <span>Settings</span>
            </a>
        </nav>
        <div class="sidebar-footer">
            <a href="index.html" class="nav-item">
                <i class="fas fa-globe"></i>
                <span>View Website</span>
            </a>
        </div>
    </aside>

    <main class="admin-main">
        <div class="page-header">
            <div>
                <h1 class="page-title">Settings</h1>
                <p class="page-subtitle">Configure application settings and preferences</p>
            </div>
            <div class="page-actions">
                <button class="btn btn-primary" id="saveSettingsBtn">
                    <i class="fas fa-save"></i> Save Changes
                </button>
                <button class="btn" id="headerRecordPaymentBtn" style="background: #f39c12; color: white; border: none; display: flex; align-items: center; gap: 8px;">
                    <i class="fas fa-hand-holding-usd"></i>
                    Record Payment
                </button>
            </div>
        </div>

        <div class="settings-container">
            <!-- Company Profile -->
            <div class="settings-group">
                <h3 class="settings-title">Company Profile</h3>
                <div class="form-row">
                    <div class="form-group">
                        <label>Company Name</label>
                        <input type="text" class="form-control" id="companyNameInput" value="RMK Groups">
                    </div>
                    <div class="form-group">
                        <label>Company GSTIN</label>
                        <input type="text" class="form-control" id="companyGstInput" value="">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Email Address</label>
                        <input type="email" class="form-control" id="companyEmailInput" value="rmkgroups1987@gmail.com">
                    </div>
                </div>
                <div class="form-row">
                    <div class="form-group">
                        <label>Phone Number</label>
                        <input type="tel" class="form-control" value="+91 99520 68848">
                    </div>
                    <div class="form-group">
                        <label>Website</label>
                        <input type="url" class="form-control" value="https://rmkgroups.in">
                    </div>
                </div>
                <div class="form-group">
                    <label>Company Address</label>
                    <textarea class="form-control" rows="2">123, Ariyalur Main Road, Perambalur, Tamil Nadu</textarea>
                </div>
            </div>

            <!-- Branding / Logo & Signature -->
            <div class="settings-group">
                <h3 class="settings-title">Branding, Logo & Signature</h3>
                <p style="color:var(--text-light); margin-bottom:1rem; font-size:0.9rem">This logo and signature will be used on all Invoices and Quotations.</p>
                <div class="form-row" style="align-items: flex-start; margin-bottom: 2rem;">
                    <div class="form-group" style="flex:1">
                        <label>Upload Logo</label>
                        <label class="file-upload-box">
                            <input type="file" id="logoUpload" accept="image/*" style="display:none">
                            <i class="fas fa-cloud-upload-alt upload-icon"></i>
                            <p style="font-weight:600">Click to upload or drag logo here</p>
                            <p style="font-size:0.8rem; color:var(--text-light)">PNG, JPG up to 2MB</p>
                        </label>
                    </div>
                    <div class="form-group"
                        style="width: 200px; padding:1rem; border:1px solid var(--border); border-radius:12px; text-align:center">
                        <label style="margin-bottom:0.5rem; display:block">Current Logo</label>
                        <img id="logoPreviewImg" src="logo.png" alt="Company Logo"
                            style="max-width:100%; height:auto; max-height:100px;">
                    </div>
                </div>

                <div class="form-row" style="align-items: flex-start;">
                    <div class="form-group" style="flex:1">
                        <label>Upload Signature</label>
                        <label class="file-upload-box">
                            <input type="file" id="sigUpload" accept="image/*" style="display:none">
                            <i class="fas fa-signature upload-icon"></i>
                            <p style="font-weight:600">Click to upload or drag signature here</p>
                            <p style="font-size:0.8rem; color:var(--text-light)">PNG with transparent background recommended</p>
                        </label>
                    </div>
                    <div class="form-group"
                        style="width: 200px; padding:1rem; border:1px solid var(--border); border-radius:12px; text-align:center">
                        <label style="margin-bottom:0.5rem; display:block">Current Signature</label>
                        <img id="sigPreviewImg" src="" alt="Authorized Signature"
                            style="max-width:100%; height:auto; max-height:100px; display:none;">
                    </div>
                </div>
            </div>

            <!-- Data Backup & Migration -->
            <div class="settings-group">
                <h3 class="settings-title"><i class="fas fa-database"></i> Database Management (Backup & Restore)</h3>
                <p style="color:var(--text-light); margin-bottom:1.5rem; font-size:0.9rem">Since data is stored securely in your browser, use these tools to transfer data between different browsers (e.g., from Edge to Chrome) or computers.</p>

                <div class="form-row" style="gap: 2rem;">
                    <div style="flex: 1; padding: 1.5rem; background: #E6F4EA; border-radius: 12px; border: 1px solid #CEEAD6;">
                        <h4 style="color: #0d652d; margin-bottom: 0.5rem;"><i class="fas fa-file-export"></i> Step 1: Export Data</h4>
                        <p style="font-size: 0.85rem; color: #137333; margin-bottom: 1.5rem;">Download a complete backup of all your customers, invoices, products, and analytics from the browser that currently has the data.</p>
                        <button type="button" class="btn btn-primary" id="btnExportFullData" style="width: 100%; justify-content: center;">
                            <i class="fas fa-download"></i> Download full Backup (.json)
                        </button>
                    </div>

                    <div style="flex: 1; padding: 1.5rem; background: #FEF7E0; border-radius: 12px; border: 1px solid #FCE8B2;">
                        <h4 style="color: #b06000; margin-bottom: 0.5rem;"><i class="fas fa-file-import"></i> Step 2: Restore Data</h4>
                        <p style="font-size: 0.85rem; color: #b06000; margin-bottom: 1.5rem;">Upload the backup file into your new browser (e.g., Chrome) to instantly restore all your records.</p>
                        <label class="btn btn-primary" style="width: 100%; justify-content: center; cursor: pointer; background: #E37400;">
                            <i class="fas fa-upload"></i> Select Backup File to Restore
                            <input type="file" id="btnImportFullData" accept=".json" style="display: none;">
                        </label>
                    </div>
                </div>

            <!-- Sequential Numbers (RESET) -->
            <div class="settings-group" style="border: 2px solid #fee2e2; background: #fffafb; padding: 1.5rem; border-radius: 12px; margin-bottom: 2rem;">
                <h3 class="settings-title" style="color: #dc2626;"><i class="fas fa-sort-numeric-up"></i> Sequential Numbers</h3>
                <p style="color:var(--text-light); margin-bottom:1.5rem; font-size:0.9rem">Use this to restart your Invoice or Quote numbers from 001. <strong>Warning:</strong> This cannot be undone.</p>
                
                <div class="form-row" style="gap: 1.5rem; display: flex;">
                    <div style="flex: 1; padding: 1rem; border: 1px solid #fecaca; border-radius: 8px;">
                        <label style="display:block; margin-bottom:0.5rem; font-weight:700;">Invoice Counter</label>
                        <button type="button" class="btn btn-outline" id="btnResetInvCounter" style="color: #dc2626; border-color: #fca5a5; width: 100%; justify-content: center;">
                            Reset Invoices to 001
                        </button>
                    </div>
                    <div style="flex: 1; padding: 1rem; border: 1px solid #fecaca; border-radius: 8px;">
                        <label style="display:block; margin-bottom:0.5rem; font-weight:700;">Quote Counter</label>
                        <button type="button" class="btn btn-outline" id="btnResetQtCounter" style="color: #dc2626; border-color: #fca5a5; width: 100%; justify-content: center;">
                            Reset Quotes to 001
                        </button>
                    </div>
                </div>
            </div>

            <!-- User Management -->
            <div class="settings-group">
                <h3 class="settings-title">User Management</h3>
                <p style="color:var(--text-light); margin-bottom:1.5rem; font-size:0.9rem">Manage administrator and staff accounts for the admin panel.</p>

                    <h4 style="margin-bottom: 1rem; color: var(--primary);">Add New User</h4>
                    <form id="addUserForm">
                        <div class="form-row">
                            <div class="form-group">
                                <label>User ID / Username</label>
                                <input type="text" id="newUserId" class="form-control" placeholder="e.g. admin123"
                                    required>
                            </div>
                            <div class="form-group">
                                <label>Full Name</label>
                                <input type="text" id="newUserName" class="form-control" placeholder="e.g. John Doe"
                                    required>
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group">
                                <label>Password</label>
                                <input type="password" id="newUserPassword" class="form-control" placeholder="••••••••"
                                    required>
                            </div>
                            <div class="form-group">
                                <label>User Role</label>
                                <select id="newUserRole" class="form-control">
                                    <option value="Admin">Administrator</option>
                                    <option value="Staff">Staff / Operator</option>
                                </select>
                            </div>
                        </div>
                        <button type="submit" class="btn btn-primary" style="margin-top: 0.5rem;">
                            <i class="fas fa-user-plus"></i> Create User
                        </button>
                    </form>
                </div>

                <div class="table-container">
                    <table class="data-table" id="usersTable">
                        <thead>
                            <tr>
                                <th>User ID</th>
                                <th>Name</th>
                                <th>Role</th>
                                <th>Status</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="usersTableBody">
                            <!-- Users will be loaded here -->
                        </tbody>
                    </table>
                </div>
            </div>

        </div>
    </main>

    <!-- Record Payment Modal -->
    <div class="modal" id="paymentModal">
        <div class="modal-overlay"></div>
        <div class="modal-container" style="max-width: 450px;">
            <div class="modal-header">
                <h2 class="modal-title">
                    <i class="fas fa-hand-holding-usd"></i>
                    Record Payment
                </h2>
                <button class="modal-close" id="closePaymentModal">
                    <i class="fas fa-times"></i>
                </button>
            </div>
            <div class="modal-body">
                <form id="paymentForm">
                    <input type="hidden" id="payInvoiceId">
                    <div class="form-section">
                        <div class="form-group" id="payCustomerGroup">
                            <label>Customer *</label>
                            <select id="payCustomerSelect" class="form-control">
                                <option value="">-- Select Customer --</option>
                            </select>
                        </div>
                        <div class="form-group" id="payInvoiceGroup" style="display:none;">
                            <label>Select Invoice *</label>
                            <select id="payInvoiceSelect" class="form-control">
                                <option value="">-- Choose Invoice --</option>
                            </select>
                        </div>
                        <div class="form-group" id="payInvNumberGroup">
                            <label>Invoice Number</label>
                            <input type="text" id="payInvNumber" class="form-control" readonly>
                        </div>
                        <div class="form-group">
                            <label>Total Amount</label>
                            <input type="text" id="payTotalAmount" class="form-control" readonly>
                        </div>
                        <div class="form-group">
                            <label>Already Received</label>
                            <input type="text" id="payAlreadyReceived" class="form-control" readonly>
                        </div>
                        <div class="form-group">
                            <label>New Received Amount (₹) *</label>
                            <input type="number" id="payNewAmount" class="form-control" required placeholder="0.00" step="0.01">
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-secondary" id="cancelPaymentBtn">Cancel</button>
                        <button type="submit" class="btn btn-primary">Save Payment</button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="admin.js"></script>
</body>

</html>